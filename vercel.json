{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    }
  ],
  "crons": [
    {
      "path": "/api/cron?box=10002&days=2",
      "schedule": "30 16 * * *"
    },
    {
      "path": "/api/cron?box=9907&days=2",
      "schedule": "0 10 * * *"
    }
  ]
}
